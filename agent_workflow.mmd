---
config:
  flowchart:
    curve: linear
---
graph TD;
	__start__([<p>__start__</p>]):::first
	collect_name(collect_name)
	collect_address(collect_address)
	confirm_order(confirm_order)
	agent(agent)
	tools(tools)
	__end__([<p>__end__</p>]):::last
	__start__ --> agent;
	agent -. &nbsp;__end__&nbsp; .-> collect_name;
	agent -.-> tools;
	collect_address -. &nbsp;ask&nbsp; .-> __end__;
	collect_address -. &nbsp;next&nbsp; .-> confirm_order;
	collect_name -. &nbsp;ask&nbsp; .-> __end__;
	collect_name -. &nbsp;next&nbsp; .-> collect_address;
	confirm_order -. &nbsp;ask&nbsp; .-> __end__;
	confirm_order -. &nbsp;next&nbsp; .-> agent;
	tools --> agent;
	classDef default fill:#f2f0ff,line-height:1.2
	classDef first fill-opacity:0
	classDef last fill:#bfb6fc
