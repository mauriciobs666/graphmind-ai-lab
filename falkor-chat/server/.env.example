# falkor-chat server — example environment (M2 live GraphRAG loop).
#
# These are the env vars the served app (`uvicorn falkorchat.app:app`) reads.
# `scripts/start_server.sh` sets sensible defaults for the demo; copy this file
# to `.env` (and `source` it) only if you run uvicorn by hand.

# ── Tenancy (single hardcoded M1 tenant — config.get_context) ──────────────────
FALKORCHAT_WS_ID=acme
FALKORCHAT_USER_ID=u1

# ── FalkorDB connection ────────────────────────────────────────────────────────
FALKORDB_HOST=127.0.0.1
FALKORDB_PORT=6379

# ── Embeddings — MUST match the workspace's vector index ───────────────────────
# ws:acme is bootstrapped at 1024 (Qwen3-Embedding-0.6B). A wrong-dim vecf32 write
# is silently accepted by the engine and then drops out of the ANN index, so the
# running app MUST be configured to the workspace's dimension.
FALKORCHAT_EMBEDDING_DIM=1024
FALKORCHAT_EMBEDDING_BASE_URL=http://localhost:1234/v1
FALKORCHAT_EMBEDDING_MODEL=text-embedding-qwen3-embedding-0.6b

# ── AI agent participant (K-013/K-014) ─────────────────────────────────────────
# Off by default so imports/tests stay network-free; the served app turns it on.
# @mentioning FALKORCHAT_AGENT_ID in a message triggers a retrieval-grounded reply.
# The id MUST match the Agent registered by `scripts/seed_demo.sh`.
FALKORCHAT_ENABLE_AGENT=1
FALKORCHAT_AGENT_ID=assistant
FALKORCHAT_AGENT_NAME=Assistant
FALKORCHAT_LLM_BASE_URL=http://localhost:1234/v1
FALKORCHAT_LLM_MODEL=qwen/qwen3-4b-2507

# ── M3 LLM-native workflow engine (K-022/K-023) ────────────────────────────────
# Off by default. When on (requires FALKORCHAT_ENABLE_AGENT=1 — the trigger holds the
# M2 responder for its no-workflow fall-through), an @mention of FALKORCHAT_AGENT_ID
# starts (or a plain reply resumes) a run of the def below; the API then schedules
# exactly one handler per message (trigger XOR responder). The def key/version MUST
# match what `scripts/seed_workflows.sh` published, or @mention-to-start never fires.
FALKORCHAT_WORKFLOW_ENABLED=0
FALKORCHAT_TRIGGER_DEF_KEY=triage
FALKORCHAT_TRIGGER_DEF_VERSION=v1
